{
  "name": "vyla-home",
  "version": "1.0.0",
  "description": "Vyla Home Desktop App Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build": "node build-pipeline.js",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "audit": "^0.0.6",
    "better-sqlite3": "^12.11.1",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "javascript-obfuscator": "^4.1.0"
  },
  "overrides": {
    "@noble/hashes": "1.5.0"
  },
  "build": {
    "appId": "com.vyla.home",
    "productName": "Vyla Home",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "service-manager.js",
      "patcher.js",
      "crypto-utils.js",
      "credential-manager.js",
      "update-client.js",
      "config/**/*",
      "build/icon.ico",
      "build/logo.txt",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}