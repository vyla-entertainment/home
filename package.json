{
  "name": "vyla-home",
  "version": "1.0.0",
  "description": "Vyla Home Desktop App Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build": "node build-pipeline.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "bytenode": "^1.5.5",
    "electron": "^43.0.0",
    "electron-builder": "^25.1.8",
    "javascript-obfuscator": "^4.1.0"
  },
  "overrides": {
    "@noble/hashes": "1.5.0"
  },
  "build": {
    "appId": "com.vyla.home",
    "productName": "Vyla Home",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "service-manager.js",
      "patcher.js",
      "crypto-utils.js",
      "credential-manager.js",
      "update-client.js",
      "integrity-verifier.js",
      "config/**/*",
      "update-payload.zip",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}